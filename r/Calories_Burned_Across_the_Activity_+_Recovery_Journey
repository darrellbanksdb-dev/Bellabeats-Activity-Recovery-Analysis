p_cal_quad <- ggplot(df_q, aes(x = quadrant, y = calories)) +
  geom_boxplot(outlier.alpha = 0.15) +
  scale_y_continuous(labels = comma) +
  labs(
    title = "Calories Burned Across the Activity + Recovery Journey",
    subtitle = "Balanced (high steps + high sleep) vs Opposite (low steps + low sleep)",
    x = "Journey segment",
    y = "Daily Calories Burned"
  ) +
  theme_minimal() +
  theme(
    axis.text.x = element_text(angle = 15, hjust = 1),
    plot.margin = margin(t = 10, r = 30, b = 10, l = 10)
  )

p_cal_quad
